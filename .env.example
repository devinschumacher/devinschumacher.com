# TinaCMS Configuration
NEXT_PUBLIC_TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-token
NEXT_PUBLIC_TINA_SEARCH_TOKEN=your-tina-search-token

# Optional: only set these when the environment already has PostHog configured.
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: set only if Tina needs an explicit public content API URL.
NEXT_PUBLIC_TINA_PUBLIC_API_URL=https://content.tinajs.io/content/your-tina-client-id/github/main
